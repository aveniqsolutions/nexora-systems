{
  "brand_identity": {
    "name": "Nexora Systems",
    "mission": "AI & Digital Transformation Consulting",
    "tone": "Enterprise, Precision, Engineered, Future-Proof",
    "archetype": "The Architect (Swiss/High-Contrast)",
    "aesthetic_goals": [
      "No gradients, no fluff.",
      "Data-driven visuals.",
      "Grid-based layouts.",
      "High contrast typography."
    ]
  },
  "typography": {
    "primary_font": "Space Grotesk",
    "secondary_font": "Inter",
    "usage": {
      "headings": "Space Grotesk, font-bold, tracking-tight, leading-none",
      "body": "Inter, font-normal, tracking-normal, leading-relaxed",
      "overline": "Inter, uppercase, tracking-[0.2em], text-xs, font-medium"
    },
    "scale": {
      "h1": "text-5xl md:text-7xl font-bold",
      "h2": "text-4xl md:text-5xl font-semibold",
      "h3": "text-2xl md:text-3xl font-medium",
      "p": "text-base md:text-lg text-muted-foreground"
    }
  },
  "colors": {
    "theme_strategy": "Dark Mode Default with Light Toggle",
    "palette": {
      "dark": {
        "background": "#050505",
        "foreground": "#F8F9FA",
        "primary": "#0F62FE",
        "secondary": "#161616",
        "border": "#333333",
        "muted": "#888888"
      },
      "light": {
        "background": "#FFFFFF",
        "foreground": "#161616",
        "primary": "#0043CE",
        "secondary": "#F4F4F4",
        "border": "#E0E0E0",
        "muted": "#525252"
      }
    },
    "utility_classes": {
      "bg_main": "bg-background",
      "text_main": "text-foreground",
      "border_main": "border-border",
      "primary_action": "bg-primary text-primary-foreground hover:bg-primary/90"
    }
  },
  "layout_strategy": {
    "container": "w-full max-w-[1400px] mx-auto px-6 md:px-12",
    "grid_system": {
      "type": "Swiss Grid",
      "columns": "grid-cols-1 md:grid-cols-12",
      "gap": "gap-0 md:gap-px bg-border",
      "cell_style": "bg-background p-8 md:p-12 border-b border-r border-border"
    },
    "section_spacing": "py-24 md:py-32",
    "forbidden_patterns": [
      "Card-based layouts (shadow box cards)",
      "Rounded corners > 8px",
      "Generic gradients",
      "Centered text blocks (unless hero)"
    ],
    "mandatory_patterns": [
      "Split screen layouts (50/50)",
      "Visible grid lines",
      "Sticky headers with backdrop blur",
      "Full-width images"
    ]
  },
  "components": {
    "buttons": {
      "style": "rounded-none or rounded-sm",
      "classes": "h-12 px-8 font-medium transition-all duration-300 active:scale-95"
    },
    "inputs": {
      "style": "underlined or minimal",
      "classes": "rounded-none border-b border-border bg-transparent focus:border-primary focus:ring-0 px-0 h-12"
    },
    "navbar": {
      "style": "glass",
      "classes": "fixed top-0 w-full z-50 border-b border-border/20 bg-background/80 backdrop-blur-md"
    },
    "cards": "DO NOT USE STANDARD CARDS. Use 'Grid Lists' where content is separated by borders."
  },
  "visual_enhancers": {
    "motion": {
      "entrance": "fade-in-up (duration-700 ease-out)",
      "hover": "text-primary transition-colors duration-200",
      "scroll": "reveal-on-scroll"
    },
    "textures": {
      "noise": "opacity-5 pointer-events-none fixed inset-0 z-50 mix-blend-overlay",
      "grid_lines": "absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"
    }
  },
  "assets": {
    "images": {
      "hero_bg": "https://images.unsplash.com/photo-1642097972624-6ed84e4fe099?q=85&w=1920&auto=format&fit=crop",
      "services_tech": "https://images.unsplash.com/photo-1645477704075-cb3d14b349ee?q=85&w=1080&auto=format&fit=crop",
      "about_office": "https://images.unsplash.com/photo-1747467327020-fb3a0225a70f?q=85&w=1080&auto=format&fit=crop",
      "team_meeting": "https://images.unsplash.com/photo-1770048532712-4fde5ef7eb90?q=85&w=1080&auto=format&fit=crop",
      "abstract_lines": "https://images.unsplash.com/photo-1772053968302-462b0203521a?q=85&w=1080&auto=format&fit=crop",
      "server_room": "https://images.unsplash.com/photo-1639094071972-a79473d1a7c6?q=85&w=1080&auto=format&fit=crop"
    },
    "icons_library": "lucide-react (Tech/Clean)"
  },
  "pages_structure": {
    "home": {
      "sections": ["Hero (Typography + Abstract Bg)", "Value Prop (Grid)", "Services Highlight (Split)", "Case Studies (List)", "CTA"]
    },
    "services": {
      "layout": "Grid list of services with detailed descriptions and icons."
    },
    "case_studies": {
      "layout": "List view. Row per study. Columns: Client, Industry, Impact, Arrow."
    },
    "contact": {
      "layout": "Split screen. Left: Info. Right: Form."
    }
  },
  "instructions_to_main_agent": [
    "Install 'lucide-react' for icons.",
    "Install 'framer-motion' for subtle entrance animations.",
    "Use 'clsx' and 'tailwind-merge' for class handling.",
    "Implement a Dark Mode toggle in the Navbar.",
    "Ensure 'Space Grotesk' is loaded via Google Fonts or similar in index.html/css.",
    "Strictly follow the 'No Card' rule. Use borders to separate content.",
    "All interactive elements MUST have 'data-testid'.",
    "Use the provided image URLs for specific sections."
  ],
  "universal_guidelines": [
    "Do not use gradients for backgrounds, use solid colors or subtle patterns.",
    "Avoid centered layouts for text-heavy sections.",
    "Use 2-3x more spacing than typical (p-12, p-16).",
    "Use 'sonner' for toasts.",
    "Ensure high contrast for accessibility.",
    "Do not use generic AI-generated text; use 'Lorem Ipsum' or realistic placeholder text.",
    "Optimize images with 'loading=lazy' where appropriate."
  ]
}